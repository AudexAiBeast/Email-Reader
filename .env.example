# Example environment variables for the mail ingestion service

# --- IMAP source mailbox ---
EMAIL_USER=you@example.com
EMAIL_PASS=your-password-or-app-password
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
MAILBOX=INBOX

# --- FTP attachment storage ---
FTP_HOST=ftp.example.com
FTP_PORT=21
FTP_USERNAME=ftpuser
FTP_PASSWORD=changeme
FTP_DIRECTORY=/
FTP_POLL_INTERVAL=30
FTP_TLS=false
FTP_PASSIVE=true

# --- MS SQL Server (TMS_importExport database) ---
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=TMS_importExport
MSSQL_USERNAME=sa
MSSQL_PASSWORD=changeme
MSSQL_DRIVER=ODBC Driver 18 for SQL Server

# --- Service tuning ---
IDLE_RENEW_SECONDS=1200
IMAP_SOCKET_TIMEOUT_SECONDS=60
IMAP_RECONNECT_BASE_SECONDS=5
IMAP_RECONNECT_MAX_SECONDS=300
GRAPHQL_MAX_PAGE_SIZE=200
LOG_LEVEL=INFO
